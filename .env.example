# Environment variables — loopsmith-hello (living reference)
#
# Copy this file to .env.local (which is gitignored) and fill in the values
# from your own Supabase project. These are PUBLIC anon keys — safe in the
# browser, safe to expose client-side. Do NOT commit .env.local, and do NOT
# put the service-role key in any NEXT_PUBLIC_* variable.

# Supabase project URL — looks like https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — the "anon" key, NOT the "service_role" key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
